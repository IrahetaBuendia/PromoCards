{
  "expo": {
    "name": "PromoCards SV",
    "slug": "promocards-sv",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "promocards",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a8a"
    },
    "android": {
      "package": "sv.promocards.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e3a8a"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sv.promocards.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "97ed9c6f-2cbd-45fa-be28-421e085301cb"
      }
    }
  }
}
